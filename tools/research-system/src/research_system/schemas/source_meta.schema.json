{
  "$defs": {
    "CaptureStatus": {
      "description": "Outcome of a capture attempt. Non-OK statuses keep failed sources visible\nto the gate so missing evidence cannot masquerade as covered (DESIGN \u00a74).",
      "enum": [
        "ok",
        "empty",
        "paywall",
        "fetch_error",
        "js_required"
      ],
      "title": "CaptureStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "author": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Author"
    },
    "capture_status": {
      "$ref": "#/$defs/CaptureStatus",
      "default": "ok"
    },
    "content_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Content Hash"
    },
    "extraction_method": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extraction Method"
    },
    "fetched_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Fetched At"
    },
    "final_url": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Final Url"
    },
    "http_status": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Http Status"
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "language": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Language"
    },
    "published_date": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Published Date"
    },
    "raw_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Raw Hash"
    },
    "title": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Title"
    },
    "url": {
      "title": "Url",
      "type": "string"
    },
    "word_count": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Word Count"
    }
  },
  "required": [
    "id",
    "url"
  ],
  "title": "SourceMeta",
  "type": "object"
}
